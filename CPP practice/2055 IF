#include<iostream>
using namespace std;

int main() {
	int t,y;
	cin >> t;
	while (t--) {
		char s[3];
		char x;
		cin >> s;
		int ans = 0;
		x = s[0];
		cin >> y;
		if ('A'<= x && x<='Z') {
			ans = y+(x - 'A'+1);
		}
		else if ('a'<= x && x<= 'z') {
			ans = y-(x - 'a' + 1);
		}
		cout << ans;
	}
	return 0;
}
